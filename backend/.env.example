# =============================================================================
# Research Contract Adviser Agent — Environment Variables
# Copy this file to `.env` and fill in your real keys.
# =============================================================================

# ------ Azure AI Foundry — Path A: Azure OpenAI (recommended) ----------------
# Use this for GPT-4o, GPT-4.1, o-series, and text-embedding-3-large.
# Endpoint looks like:  https://<your-resource>.openai.azure.com
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
# These are *deployment names* you create in Foundry, NOT model names.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-large

# ------ Azure AI Foundry — Path B: Serverless / MaaS endpoint ---------------
# Use this for Llama-3, Mistral Large, Phi, etc. exposed via Foundry MaaS.
# Endpoint looks like:  https://<deployment>.<region>.models.ai.azure.com
FOUNDRY_ENDPOINT=
FOUNDRY_API_KEY=
FOUNDRY_MODEL=

# auto = prefer Azure OpenAI when configured, fallback to MaaS, then mock.
# Override with: azure-openai | foundry-maas
LLM_BACKEND=auto

# ------ App config ----------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_UPLOAD_MB=20
